# Polymarket Wallet
# POLYMARKET_PK       = MetaMask EOA private key (signs orders)
# POLYMARKET_FUNDER   = Polymarket proxy address that holds USDC
#                       (visible at polymarket.com → Deposit)
# POLYMARKET_SIG_TYPE = 0 EOA · 1 POLY_PROXY · 2 POLY_GNOSIS_SAFE
#                       MetaMask users today are usually 2 (Gnosis Safe).
#                       If unsure, run: python scripts/check_wallet.py
POLYMARKET_PK=54f9cdcff6a74c58f24c117ec715462c946b02a4ab1630eea39995ea2f511a79
POLYMARKET_FUNDER=0x23342a623A760cf11cFdc1736f8B05cf7A70A3F4
POLYMARKET_SIG_TYPE=2

# Polymarket CLOB API Credentials
POLYMARKET_API_KEY=12753968-aa5f-bf91-f1d4-ba01dd816a27
POLYMARKET_API_SECRET=HuNW4zIkLVvb1hP5hsB-wFfscffK0602IP6oXw2e-vg=
POLYMARKET_PASSPHRASE=7fc88e236062e04619e464e57243b460feb585dcc58a4299440e4ab6825b3bb1

ETH_RPC_URL=https://mainnet.infura.io/v3/aeede04b2b444325b5382405be956138

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Trading Parameters ───────────────────────────────────────────
MAX_POSITION_SIZE=1.0
MARKET_BUY_USD=10.00

# ENABLE_STOP_LOSS
#   false → stop-loss is DISABLED. Positions are only closed by
#           TAKE-PROFIT or by Polymarket SETTLEMENT.
#   true  → stop-loss is enforced at the dynamically-scaled SL price.
#
# ── Entry-price-scaled SL/TP (the actual logic used) ──────────────
# The SL and TP fractions are no longer flat — they scale linearly by
# entry price across the [MIN_ENTRY_PRICE, MAX_ENTRY_PRICE] band:
#
#   sl_frac = interp(SL_PCT_AT_MIN_ENTRY, SL_PCT_AT_MAX_ENTRY, entry)
#   tp_frac = interp(TP_PCT_AT_MIN_ENTRY, TP_PCT_AT_MAX_ENTRY, entry)
#
#   SL price = entry × (1 − sl_frac)         # frac of capital at risk
#   TP price = entry + tp_frac × (1 − entry) # frac of remaining upside
#
# Why scale: at HIGH entry prices the binary token has little room to
# 1.0 (small max gain), so the SL must tighten and the TP must fire
# sooner to keep R:R reasonable. At LOW entry prices the asymmetric
# upside dwarfs the SL, so we can afford a wider SL and let winners
# ride longer toward settlement.
#
# Defaults below give this matrix:
#
#   entry 0.25  sl_frac=40%  tp_frac=70%  SL=$0.15  TP=$0.775  R:R 5.3:1
#   entry 0.40  sl_frac=34%  tp_frac=63%  SL=$0.27  TP=$0.778  R:R 2.8:1
#   entry 0.50  sl_frac=30%  tp_frac=58%  SL=$0.35  TP=$0.788  R:R 1.9:1
#   entry 0.60  sl_frac=26%  tp_frac=53%  SL=$0.45  TP=$0.810  R:R 1.4:1
#   entry 0.75  sl_frac=20%  tp_frac=45%  SL=$0.60  TP=$0.863  R:R 0.75:1
#
# The legacy STOP_LOSS_PCT / TAKE_PROFIT_PCT below are only used as
# fallback defaults if pending overrides are set programmatically.
ENABLE_STOP_LOSS=true
STOP_LOSS_PCT=0.20
TAKE_PROFIT_PCT=0.60

# Per-entry-price endpoints. Lower entry → wider SL + patient TP.
# Higher entry → tighter SL + faster TP.
# Calibrated for the new band [0.30, 0.65]:
#   entry 0.30  sl_frac=40%  tp_frac=70%  SL=$0.18  TP=$0.769  R:R 5.3:1
#   entry 0.40  sl_frac=35%  tp_frac=65%  SL=$0.26  TP=$0.764  R:R 2.9:1
#   entry 0.50  sl_frac=30%  tp_frac=60%  SL=$0.35  TP=$0.800  R:R 2.0:1
#   entry 0.55  sl_frac=28%  tp_frac=58%  SL=$0.40  TP=$0.811  R:R 1.6:1
#   entry 0.65  sl_frac=22%  tp_frac=50%  SL=$0.51  TP=$0.825  R:R 0.9:1
SL_PCT_AT_MIN_ENTRY=0.40
SL_PCT_AT_MAX_ENTRY=0.22
TP_PCT_AT_MIN_ENTRY=0.70
TP_PCT_AT_MAX_ENTRY=0.50

# Refuse to enter when the token price is outside this band.
# Buying at 0.95 means "pay 95c to win 5c" → terrible R:R, skip it.
MIN_ENTRY_PRICE=0.30
MAX_ENTRY_PRICE=0.65

# Refuse to enter when the bid-ask spread is wider than this fraction
# of the mid price (Polymarket BTC 15-min markets often quote 1c spread
# on a sub-$1 token → 1-3% of EV gone before the trade starts).
MAX_SPREAD_PCT=0.05

# Minimum seconds between two entry attempts on the same market.
# Combined with TRADE_WINDOW_SEC_{START,END} this caps the burst rate
# but lets the bot re-enter several times per 15-min market.
ENTRY_COOLDOWN_SEC=90

# Trade window inside each 15-min market, in seconds-from-market-open.
# 300-780 = minutes 5-13. The old default (540-600) was a 1-minute slot
# at the very end and capped throughput at 4 trades/hour.
TRADE_WINDOW_SEC_START=540
TRADE_WINDOW_SEC_END=780

# Refuse any new entry this close to market settlement (FAK reject risk
# spikes and the binary outcome is about to pay out anyway).
LATE_ENTRY_CUTOFF_SEC=120

# When a pre-trade filter (band / spread / liquidity) rejects, wait
# this many seconds before re-evaluating — otherwise the bot busy-loops
# at full tick rate (~10/s) on the same price.
FILTER_REJECT_COOLDOWN_SEC=15

# ── Per-market constraints (prevents "win then fade" loss pattern) ─
# Lock the direction of the first trade on each market — if the first
# trade on market X was LONG, refuse SHORTs on X until it expires.
# After a winning LONG the divergence/spike processors often flip the
# fusion to BEARISH; in 15-min binary markets that contrarian fade
# usually loses because the trend continues to settlement.
LOCK_MARKET_DIRECTION=true

# Cap entries per 15-min market.
#   1 → one bet per market (most conservative)
#   2 → allow one pyramid bet only if signals get STRONGER (see
#       PYRAMID_MIN_FUSION_SCORE below). All other rails still apply:
#       same direction (LOCK_MARKET_DIRECTION), better price (anti-chase),
#       cooldown elapsed (ENTRY_COOLDOWN_SEC), ML edge passes.
MAX_TRADES_PER_MARKET=2

# Refuse to re-enter on the same market at a price more than this
# many cents WORSE than the last entry on the same market — i.e.
# don't chase a token whose price has run away from us.
MAX_CHASE_DELTA=0.12

# Pyramid quality gate. The first entry uses the regular fusion
# threshold (55). The 2nd+ entry on the same market must have a
# fusion score >= this value. Set to 100 to effectively disable
# pyramiding even if MAX_TRADES_PER_MARKET > 1.
PYRAMID_MIN_FUSION_SCORE=70

# ── Signal-reversal exit (early SL based on signals, not price) ──
# While a position is open, every SIGNAL_REVERSAL_CHECK_SEC seconds
# the bot re-runs the 10 signal processors against the position's
# market. If fusion direction has flipped OPPOSITE to the position
# with a strong score for SIGNAL_REVERSAL_CONFIRM_COUNT checks in a
# row, the position is closed immediately via market sell — even if
# the price has not yet reached the stop-loss.
#
# This catches losing trades BEFORE the slippage tail of an SL exit,
# and exits during the natural window between TP and SL where price
# is drifting against you but hasn't crossed either threshold.
#
#   ONLY_IF_LOSING=true → only bail out of underwater positions; lets
#                         winning positions ride to TP (recommended)
#   GRACE_SEC           → don't second-guess a fresh trade for N sec
#                         (default 30 — gives the trade time to develop)
#   MIN_SCORE           → fusion score required to count as a real flip
#                         (65 is firm consensus, 55 is borderline noise)
#   CONFIRM_COUNT       → consecutive checks needed before exiting
#                         (2 = roughly 2 minutes of sustained reversal
#                          at the default CHECK_SEC=60)
ENABLE_SIGNAL_REVERSAL_EXIT=true
SIGNAL_REVERSAL_CHECK_SEC=60
SIGNAL_REVERSAL_MIN_SCORE=65
SIGNAL_REVERSAL_CONFIRM_COUNT=2
SIGNAL_REVERSAL_ONLY_IF_LOSING=true
SIGNAL_REVERSAL_GRACE_SEC=30

# ── ML edge threshold ────────────────────────────────────────────
# Minimum gap (in probability points) between the ML model's p(UP)
# and Polymarket's implied probability before the bot will fire a
# bet. 0.10 = "only bet when our prediction is at least 10 percentage
# points better than Polymarket's price".
#
# Applies on the ML-active code path (once the model has trained on
# MIN_SAMPLES=200 outcomes). While ML is still warming up the bot
# falls back to fusion-consensus signals, which have their own filter
# (min_signals=2 and consensus score >= 55).
MIN_ML_EDGE=0.07

# Signal-processor thresholds
SPIKE_THRESHOLD=0.08
DIVERGENCE_THRESHOLD=0.06
